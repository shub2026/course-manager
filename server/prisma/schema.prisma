generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model audit_logs {
  id          Int      @id @default(autoincrement())
  action      String
  module      String
  operator_id Int?
  ip          String?
  details     String?
  result      String
  message     String?
  created_at  DateTime @default(now())
  users       users?   @relation(fields: [operator_id], references: [id])

  @@index([created_at(sort: Desc)])
  @@index([operator_id])
  @@index([module])
  @@index([action])
}

model classes {
  id                Int              @id @default(autoincrement())
  name              String
  enrollment_year   Int
  duration_years    Int
  major_id          Int?
  college_id        Int?
  training_level_id Int?
  student_count     Int
  custom_plan_id    Int?
  status            String           @default("active")
  created_at        DateTime         @default(now())
  updated_at        DateTime         @updatedAt
  training_plans    training_plans?  @relation(fields: [custom_plan_id], references: [id])
  training_levels   training_levels? @relation(fields: [training_level_id], references: [id])
  colleges          colleges?        @relation(fields: [college_id], references: [id])
  majors            majors?          @relation(fields: [major_id], references: [id])

  @@index([status])
  @@index([enrollment_year])
  @@index([major_id, status])
  @@index([training_level_id])
  @@index([college_id])
}

model colleges {
  id             Int              @id @default(autoincrement())
  name           String           @unique
  code           String?
  description    String?
  sort_order     Int              @default(0)
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt
  classes        classes[]
  training_plans training_plans[]
}

model courses {
  id           Int            @id @default(autoincrement())
  name         String
  code         String?
  type         String         @default("public")
  description  String?
  sort_order   Int            @default(0)
  created_at   DateTime       @default(now())
  updated_at   DateTime         @updatedAt
  plan_courses plan_courses[]

  @@index([type])
  @@index([code])
}

model majors {
  id             Int              @id @default(autoincrement())
  name           String
  code           String?
  description    String?
  sort_order     Int              @default(0)
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt
  classes        classes[]
  training_plans training_plans[]
}

model plan_course_semesters {
  id             Int              @id @default(autoincrement())
  plan_course_id Int
  semester       Int
  weekly_hours   Float
  weeks_count    Int              @default(18)
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt
  plan_courses   plan_courses     @relation(fields: [plan_course_id], references: [id], onDelete: Cascade)
  plan_textbooks plan_textbooks[]

  @@unique([plan_course_id, semester])
}

model plan_courses {
  id                    Int                     @id @default(autoincrement())
  plan_id               Int
  course_id             Int
  start_semester        Int
  end_semester          Int
  weekly_hours          Float
  weeks_per_semester    Int                     @default(18)
  sort_order            Int                     @default(0)
  created_at            DateTime                @default(now())
  updated_at            DateTime                @updatedAt
  plan_course_semesters plan_course_semesters[]
  courses               courses                 @relation(fields: [course_id], references: [id])
  training_plans        training_plans          @relation(fields: [plan_id], references: [id], onDelete: Cascade)

  @@unique([plan_id, course_id])
  @@index([plan_id])
  @@index([course_id])
}

model plan_textbooks {
  id                    Int                   @id @default(autoincrement())
  semester_id           Int
  textbook_id           Int
  is_required           Boolean               @default(true)
  created_at            DateTime              @default(now())
  // updated_at 字段需要在下次系统重置时添加
  // updated_at            DateTime              @updatedAt
  textbooks             textbooks             @relation(fields: [textbook_id], references: [id])
  plan_course_semesters plan_course_semesters @relation(fields: [semester_id], references: [id], onDelete: Cascade)
}

model system_settings {
  id          Int     @id @default(autoincrement())
  key         String  @unique
  value       String
  description String?
  // 注意：created_at 和 updated_at 字段需要在下次系统重置时添加
  // created_at  DateTime @default(now())
  // updated_at  DateTime @updatedAt
}

model textbooks {
  id             Int              @id @default(autoincrement())
  title          String
  isbn           String?
  publisher      String?
  author         String?
  edition        String?
  // publish_date 字段保持 String 类型以匹配现有 SQLite TEXT 列，下次系统重置时可改为 DateTime
  publish_date   String?
  price          Float?
  category       String?
  description    String?
  is_active      Boolean          @default(true)
  sort_order     Int              @default(0)
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt
  plan_textbooks plan_textbooks[]

  @@index([is_active])
  @@index([category])
  @@index([isbn])
}

model training_levels {
  id             Int              @id @default(autoincrement())
  name           String           @unique
  code           String?
  description    String?
  sort_order     Int              @default(0)
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt
  classes        classes[]
  training_plans training_plans[]
}

model training_plans {
  id                Int              @id @default(autoincrement())
  name              String
  major_id          Int?
  college_id        Int?
  training_level_id Int?
  version           String?
  description       String?
  sort_order        Int              @default(0)
  created_at        DateTime         @default(now())
  updated_at        DateTime         @updatedAt
  classes           classes[]
  plan_courses      plan_courses[]
  training_levels   training_levels? @relation(fields: [training_level_id], references: [id])
  colleges          colleges?        @relation(fields: [college_id], references: [id])
  majors            majors?          @relation(fields: [major_id], references: [id])
}

model users {
  id            Int          @id @default(autoincrement())
  username      String       @unique
  password      String
  role          String       @default("viewer")
  real_name     String?
  email         String?
  is_active     Boolean      @default(true)
  last_login_at DateTime?
  created_at    DateTime     @default(now())
  updated_at    DateTime         @updatedAt
  audit_logs    audit_logs[]

  @@index([role])
  @@index([username])
}
