{
  "name": "course-management-server",
  "version": "1.0.2",
  "description": "KEC课程管理平台后端",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch-path=src src/server.js",
    "start": "node src/server.js",
    "diagnose": "node scripts/diagnose.js",
    "init:settings": "node scripts/init-settings.js",
    "db:migrate": "npx prisma migrate dev",
    "db:generate": "npx prisma generate",
    "db:seed": "node prisma/seed.js",
    "db:seed:dev": "DEV_SEEDS=true node prisma/seed.js",
    "db:seed:reset": "FORCE_RESET=true node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "prisma": "^6.19.3"
  }
}
