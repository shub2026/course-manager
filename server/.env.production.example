# ==================== 生产环境配置示例 ====================
# 复制此文件为 .env 并修改相应的值

# 环境变量
NODE_ENV=production

# 数据库配置（生产环境建议使用 MySQL）
# SQLite 方式（小型部署）：
DATABASE_URL="file:/var/www/kec-manager/server/data/kec.db"
# MySQL 方式（推荐，取消注释并修改）：
# DATABASE_URL="mysql://username:password@localhost:3306/kec_manager"

# 服务器端口
PORT=3000

# JWT密钥（必须配置，请使用以下命令生成随机密钥）
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_generated_hex_string_here_minimum_32_characters
JWT_REFRESH_SECRET=another_generated_hex_string_here_minimum_32_characters
JWT_DOWNLOAD_SECRET=third_generated_hex_string_here_minimum_32_characters

# JWT过期时间
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS 允许的源（逗号分隔，包含生产域名）
CORS_ORIGINS=https://kec.sntip.cn,https://www.kec.sntip.cn

# 日志级别：error, warn, info, debug
LOG_LEVEL=info

# 文件上传大小限制（MB）
MAX_FILE_SIZE=10
